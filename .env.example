APP_NAME=interviewer-agent
ENV=dev

# SQLite（默认）
DATABASE_URL=sqlite:///./app.db
# PostgreSQL 示例：
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/interviewer_agent

LLM_PROVIDER=mock
LLM_MODEL=mock-interviewer-v1
PROMPT_VERSION=v1
SCORING_BACKEND=provider

GEMINI_API_KEY=
OPENAI_API_KEY=
FIRECRAWL_API_KEY=

MAX_TURNS=8
LOG_LEVEL=INFO
